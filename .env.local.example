# Supabase Configuration
# Get these values from your Supabase project dashboard

# URL of your Supabase project (e.g., https://xyzabc123.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key (found in Settings > API > Project API keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Service role key - ONLY use in server-side code, never expose to client
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# GOOGLE OAUTH SETUP (in Supabase Dashboard)
# ============================================
# 1. Go to Authentication > Providers > Google
# 2. Enable Google OAuth
# 3. Add your Google Cloud credentials:
#    - SUPABASE_GOOGLE_CLIENT_ID
#    - SUPABASE_GOOGLE_CLIENT_SECRET
# 4. Add redirect URLs:
#    - http://localhost:3000/auth/callback
#    - https://your-production-domain.com/auth/callback
# ============================================